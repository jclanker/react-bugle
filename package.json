{
  "name": "react-bugle",
  "version": "0.1.0",
  "description": "React notification component with context-based state management",
  "main": "dist/index.cjs.js",
  "module": "dist/index.esm.js",
  "exports": {
    ".": {
      "import": "./dist/index.esm.js",
      "require": "./dist/index.cjs.js"
    },
    "./iconless": {
      "import": "./dist/index_iconless.esm.js",
      "require": "./dist/index_iconless.cjs.js"
    },
    "./themed": {
      "import": "./dist/index_themed.esm.js",
      "require": "./dist/index_themed.cjs.js"
    },
    "./themed-iconless": {
      "import": "./dist/index_themed_iconless.esm.js",
      "require": "./dist/index_themed_iconless.cjs.js"
    }
  },
  "scripts": {
    "test": "jest",
    "start": "rollup -c rollup.demo.config.mjs -w",
    "build-demo": "rollup -c rollup.demo.config.mjs",
    "build": "rollup -c"
  },
  "keywords": [
    "react",
    "context",
    "component",
    "notification"
  ],
  "author": "jclanker",
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/jclanker/react-bugle"
  },
  "bugs": {
    "url": "https://github.com/jclanker/react-bugle/issues"
  },
  "dependencies": {
    "@babel/runtime": "^7.29.2",
    "react-icons": "^5.6.0"
  },
  "devDependencies": {
    "styled-components": "^6.3.12",
    "@babel/core": "^7.29.0",
    "@babel/plugin-transform-runtime": "^7.29.0",
    "@babel/preset-env": "^7.29.2",
    "@babel/preset-react": "^7.28.5",
    "@rollup/plugin-babel": "^7.0.0",
    "@rollup/plugin-commonjs": "^29.0.2",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-replace": "^6.0.3",
    "@testing-library/jest-dom": "^5.17.0",
    "@testing-library/react": "^14.0.0",
    "jest": "^27.5.1",
    "jest-styled-components": "^7.2.0",
    "prettier": "^2.6.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-select": "^5.8.0",
    "rollup": "^4.60.1",
    "rollup-plugin-copy": "^3.5.0",
    "rollup-plugin-livereload": "^2.0.5",
    "rollup-plugin-serve": "^3.0.0",
    "styled-reboot": "^5.0.0"
  },
  "peerDependencies": {
    "react": ">=18.3.1",
    "react-dom": ">=18.3.1",
    "styled-components": ">=5.1"
  },
  "peerDependenciesMeta": {
    "styled-components": {
      "optional": true
    }
  },
  "license": "MIT",
  "sideEffects": false
}
